generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  MANAGER
  INSPECTOR
  USER
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum PackageType {
  ALL
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  CANCELLED
}

enum AffiliateStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum PresentationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  role            Role     @default(USER)

  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)

  avatarUrl       String?

  affiliateCode   String   @unique
  affiliateLink   String   @unique

  totalEarnings   Float    @default(0)
  pendingEarnings Float    @default(0)

  // 🟢 نظام الإحالة المباشر (3 مستويات) - Self-Relation
  referredById    String?
  referredBy      User?    @relation("ReferralSystem", fields: [referredById], references: [id])
  referrals       User[]   @relation("ReferralSystem")

  otps            Otp[]
  refreshTokens   RefreshToken[]
  purchases       UserCourse[]

  // علاقات جدول تتبع العمولات (الأفلييت)
  referredTracking AffiliateTracking[] @relation("ReferredUser")
  referrerTracking AffiliateTracking[] @relation("ReferrerUser")

  sentPresentations      PresentationInvite[] @relation("SentInvites")
  receivedPresentations  PresentationInvite[] @relation("ReceivedInvites")

  withdrawalRequests WithdrawalRequest[]
  
  certificates Certificate[]

  // نظام المفتشين (Inspectors)
  assignedCourses Course[]         @relation("CourseInspectors")
  writtenNotes    InspectorNote[] @relation("InspectorNotes")
  receivedNotes   InspectorNote[] @relation("StudentNotes")

  lessonProgress LessonProgress[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLoginAt     DateTime?

  @@index([email])
  @@index([affiliateCode])
  @@index([role])
}

//////////////////////////////////////////////////////

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt  DateTime
  isRevoked  Boolean  @default(false)

  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////

model Otp {
  id         String   @id @default(uuid())

  code       String
  type       OtpType

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt  DateTime
  isUsed     Boolean  @default(false)

  attempts   Int      @default(0)

  ipAddress  String?

  createdAt  DateTime @default(now())

  @@index([userId, type])
}

//////////////////////////////////////////////////////

model Course {
  id                String       @id @default(uuid())

  title             String
  slug              String       @unique

  description       String
  shortDescription  String?

  thumbnailUrl      String?
  previewVideoUrl   String?

  status            CourseStatus @default(DRAFT)

  packageType       PackageType  @default(BASIC)
  
  // 🔴 الإضافة الجديدة فقط: حقل نصي حر يقبل أي مجال تكتبه أو تختاره
  category          String?

  originalPrice     Float
  salePrice         Float?

  currency          String       @default("USD")

  commissionRate    Float        @default(15)

  duration          Int?
  totalLessons      Int          @default(0)

  language          String       @default("ar")
  level             String       @default("beginner")

  tags              String?

  sections          CourseSection[]
  purchases         UserCourse[]
  affiliateTracking AffiliateTracking[]

  inspectors     User[]           @relation("CourseInspectors")
  inspectorNotes InspectorNote[]

  certificates Certificate[]

  lessonProgress LessonProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([slug])
}

//////////////////////////////////////////////////////

model CourseSection {
  id        String   @id @default(uuid())

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title     String
  order     Int

  lessons   Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

//////////////////////////////////////////////////////

model Lesson {
  id             String        @id @default(uuid())

  sectionId      String
  section        CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  title          String
  description    String?

  videoUrl       String?
  thumbnailUrl   String?
  videoDuration  Int?

  order          Int

  isFreePreview  Boolean       @default(false)
  isPublished    Boolean       @default(true)

  attachments    String?

  progress       LessonProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
}

//////////////////////////////////////////////////////

model UserCourse {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  status    PurchaseStatus @default(PENDING)

  amountPaid      Float
  currency        String @default("USD")

  paymentMethod   String?
  paymentRef      String? @unique

  progressPercent Float    @default(0)

  lastAccessedAt  DateTime?
  completedAt     DateTime?

  affiliateTrackingId String?
  affiliateTracking   AffiliateTracking? @relation(fields: [affiliateTrackingId], references: [id], onDelete: Cascade)

  purchasedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, courseId])
}

//////////////////////////////////////////////////////

model AffiliateTracking {
  id               String          @id @default(uuid())

  referrerId       String
  referrer         User            @relation("ReferrerUser", fields: [referrerId], references: [id], onDelete: Cascade)

  referredUserId   String
  referredUser     User            @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  courseId         String?
  course           Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // 🟢 حقل المستوى (Tier): 1=مباشر، 2=مستوى ثانٍ، 3=مستوى ثالث
  tier             Int             @default(1)

  commissionAmount Float           @default(0)
  commissionRate   Float           @default(0)

  status           AffiliateStatus @default(PENDING)

  purchases        UserCourse[]

  referralIp       String?
  registrationIp   String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // ملحوظة: شلنا الـ Unique بين المسوق والطالب عشان الطالب الواحد ممكن يعمل عمولات مستويات مختلفة وكورسات مختلفة
  @@index([referrerId])
  @@index([referredUserId])
}

//////////////////////////////////////////////////////

model PresentationInvite {
  id String @id @default(uuid())

  senderId String
  sender   User   @relation("SentInvites", fields: [senderId], references: [id], onDelete: Cascade)

  inspectorId String
  inspector   User   @relation("ReceivedInvites", fields: [inspectorId], references: [id], onDelete: Cascade)

  attendeeIds String[] 

  title   String
  message String?

  scheduledAt DateTime?
  meetingUrl  String?

  status PresentationStatus @default(PENDING)

  responseMessage String?
  respondedAt      DateTime?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////

model WithdrawalRequest {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount   Float
  currency String @default("USD")

  method          String
  accountDetails  String

  status WithdrawalStatus @default(PENDING)

  processedAt DateTime?
  adminNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid())

  userId String?

  action       String
  resource     String
  resourceId   String?

  ipAddress String?
  userAgent String?

  metadata  String?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////

model InspectorNote {
  id          String   @id @default(uuid())

  inspectorId String
  inspector   User     @relation("InspectorNotes", fields: [inspectorId], references: [id], onDelete: Cascade)

  studentId   String
  student     User     @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)

  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  note        String   @db.Text
  
  emailSent   Boolean  @default(false) 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([inspectorId])
  @@index([studentId])
  @@index([courseId])
}

//////////////////////////////////////////////////////

model Package {
  id           String   @id @default(uuid())
  
  name         String
  price        Float
  thumbnailUrl String?
  coursesCount Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

//////////////////////////////////////////////////////

model LessonProgress {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  watchedAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId, courseId])
}

//////////////////////////////////////////////////////

model Certificate {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  certNumber  String   @unique

  issuedAt    DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([certNumber]) 
  @@index([issuedAt])
}